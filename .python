# 无类型版本 —— 改成有类型的
from typing import Dict,List,Tuple,Optional,Union
def process_geo_data(name, coordinates, attributes):
    """处理地理数据"""
    lat, lon = coordinates
    elevation = attributes.get("elevation")
    province = attributes.get("province")
    return {
        "name": name,
        "lat": lat,
        "lon": lon,
        "elevation": elevation,
        "province": province,
    }

# 期望调用方式：
result = process_geo_data(
    "太白山",
    (33.96, 107.77),
    {"elevation": 3767, "province": "陕西省"}
)
